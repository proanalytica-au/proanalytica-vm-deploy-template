# ────────────────────────────────────────────────────
# Application environment variables (PRODUCTION)
# ────────────────────────────────────────────────────
# Copy to .env.prod and fill in actual values.
# .env.prod is git-ignored (see .gitignore).

# App
NODE_ENV=production
PORT=3000

# Service integrations
# API_KEY=

# TLS proxy
PROXY_HTTPS_PORT=443
SSL_CERT_PATH=./certs/origin.crt
SSL_KEY_PATH=./certs/origin.key

# ── Optional: Database ──
# DATABASE_URL=postgresql://user:pass@postgres:5432/db
# POSTGRES_DB=
# POSTGRES_USER=
# POSTGRES_PASSWORD=

# ── Optional: External services ──
# SENDGRID_API_KEY=
# REDIS_URL=